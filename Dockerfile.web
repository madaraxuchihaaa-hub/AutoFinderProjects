# syntax=docker/dockerfile:1
# Статический Expo web → nginx (см. docker/nginx).
FROM node:22-bookworm-slim AS builder

WORKDIR /app

ARG EXPO_PUBLIC_API_URL=
ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL

COPY package.json package-lock.json ./
# Peer-deps: RN 0.81 vs react-native-screens. postinstall тянет server/ — в этом образе сервер не нужен, отключаем скрипты.
RUN npm ci --legacy-peer-deps --ignore-scripts

COPY app.json babel.config.js tsconfig.json index.ts ./
COPY src ./src

ENV NODE_ENV=production
RUN npx expo export --platform web

FROM nginx:1.27-alpine

COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
