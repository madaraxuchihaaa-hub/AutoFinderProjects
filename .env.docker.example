# Скопируйте в .env.docker и подставьте свои значения (docker compose подхватит через env_file при необходимости).
# Либо экспортируйте переменные в shell перед `docker compose up`.

JWT_SECRET=замените-на-случайную-строку-32-плюс-символов
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=autofinder
API_PORT=3000
WEB_PORT=8080
# Демо-объявления в БД при первом пустом каталоге: 1 или 0
AUTO_SEED_DEMO=0
