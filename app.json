{
  "expo": {
    "name": "AutoFinder",
    "slug": "autofinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "autofinder",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#B8B8B8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.autofinder.app"
    },
    "android": {
      "package": "com.autofinder.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B8B8B8"
      },
      "navigationBar": {
        "backgroundColor": "#0E141C"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "AutoFinder нужен доступ к фото для объявлений."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ef483890-a6ca-4362-bf55-d255e54352d6"
      }
    }
  }
}
