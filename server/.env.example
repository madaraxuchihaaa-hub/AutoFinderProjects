# Локально: отдельные переменные ИЛИ одна строка (как на Railway):
# DATABASE_URL=postgresql://user:pass@host:5432/railway

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=1221
PGDATABASE=autofinder
PORT=3000
AUTO_SEED_DEMO=0

# Обязательно для входа и регистрации (случайная строка 32+ символов):
JWT_SECRET=change-me-to-a-long-random-secret
