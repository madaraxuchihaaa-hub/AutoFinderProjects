# Локально: отдельные переменные ИЛИ одна строка (как на Railway):
# DATABASE_URL=postgresql://user:pass@host:5432/railway

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=1221
PGDATABASE=autofinder
PORT=3000

# JWT — мобильный клиент (POST /api/mobile/login).
JWT_SECRET=change-me-to-a-long-random-secret

# Cookie-сессии для веба (POST /api/auth/login); можно совпадать с JWT_SECRET только локально.
SESSION_SECRET=change-me-to-another-long-random-secret

# Опционально: origin веб-клиента (Vite по умолчанию http://localhost:5173).
# WEB_ORIGIN=http://localhost:5173
